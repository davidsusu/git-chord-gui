{
  "name": "git-chord",
  "displayName": "Git Chord",
  "description": "%gitChord.extension.description%",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:git-chord.about",
    "onCommand:git-chord.cliHelp",
    "onCommand:git-chord.repoState",
    "onCommand:git-chord.createSnapshot",
    "onCommand:git-chord.repoStateFromExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-chord.about",
        "title": "%gitChord.commands.about%"
      },
      {
        "command": "git-chord.cliHelp",
        "title": "%gitChord.commands.cliHelp%"
      },
      {
        "command": "git-chord.repoState",
        "title": "%gitChord.commands.repoState%"
      },
      {
        "command": "git-chord.createSnapshot",
        "title": "%gitChord.commands.createSnapshot%"
      },
      {
        "command": "git-chord.repoStateFromExplorer",
        "title": "%gitChord.commands.repoState%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "git-chord.about"
        },
        {
          "command": "git-chord.cliHelp"
        },
        {
          "command": "git-chord.repoState"
        },
        {
          "command": "git-chord.createSnapshot"
        },
        {
          "command": "git-chord.repoStateFromExplorer",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "git-chord.repoStateFromExplorer",
          "when": "resourceScheme == file",
          "group": "git-chord@10"
        }
      ]
    },
    "configuration": {
      "title": "Git Chord",
      "properties": {
        "gitChord.commandPath": {
          "type": "string",
          "default": "",
          "description": "%gitChord.config.commandPath%"
        },
        "gitChord.openOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "%gitChord.config.openOnStartup%"
        },
        "gitChord.language": {
          "type": "string",
          "enum": [
            "en-US",
            "hu-HU"
          ],
          "enumItemLabels": [
            "%gitChord.config.language.enUS%",
            "%gitChord.config.language.huHU%"
          ],
          "default": "en-US",
          "description": "%gitChord.config.language%"
        }
      }
    }
  },
  "scripts": {
    "test": "npm run compile-web",
    "vscode:prepublish": "npm run package-web",
    "compile-web": "webpack",
    "watch-web": "webpack --watch",
    "package-web": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/assert": "^1.5.10",
    "@types/mocha": "^10.0.8",
    "@types/node": "^22.7.9",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.94.0",
    "@types/webpack-env": "^1.18.5",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "@vscode/test-web": "^0.0.61",
    "assert": "^2.1.0",
    "eslint": "^9.11.1",
    "mocha": "^10.7.3",
    "process": "^0.11.10",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@git-chord/gui-core": "file:../core/package-dist/git-chord-gui-core-0.1.0-SNAPSHOT.tgz",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.1.2",
    "react-router-dom": "^6.27.0"
  }
}
