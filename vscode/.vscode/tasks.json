{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-extension",
			"type": "shell",
			"command": "./build.sh",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$ts-webpack"
			]
		},
		{
			"label": "watch-extension",
			"type": "npm",
			"script": "watch-web",
			"group": "build",
			"isBackground": true,
			"problemMatcher": [
				"$ts-webpack-watch"
			]
		}
	]
}
